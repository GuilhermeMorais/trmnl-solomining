<div class="layout layout--col">
  <div class="grid grid--cols-2 gap--small">
    <div class="item">
      <div class="meta"><span class="label label--small">Status</span></div>
      <div class="content flex flex--row flex--align-center gap--small">
        <span class="value">{% if is_online %}Online{% else %}Offline{% endif %}</span>
        <span class="label {% if is_online %}label--success{% else %}label--error{% endif %}">
          {% if is_online %}OK{% else %}Down{% endif %}
        </span>
      </div>
    </div>

    <div class="item">
      <div class="meta"><span class="label label--small">Best Diff</span></div>
      <div class="content"><span class="value text--warning">{{ best_difficulty_display }}</span></div>
    </div>
  </div>

  <div class="item mt--2 item--emphasis-2">
    <div class="meta"><span class="label label--small">Hashrate</span></div>
    <div class="content"><span class="value value--large text--primary" data-fit-value="true">{{ hashrate_display }}</span></div>
  </div>

  <div class="grid grid--cols-2 gap--small mt--1">
    <div class="item">
      <div class="meta"><span class="label label--small">Uptime</span></div>
      <div class="content"><span class="value">{{ uptime_label }}</span></div>
    </div>
    <div class="item">
      <div class="meta"><span class="label label--small">Last Seen</span></div>
      <div class="content"><span class="value">{{ last_seen_label }}</span></div>
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">Solo Mining</span>
  <span class="instance">
    {{ "now" | date: '%s' | plus: trmnl.user.utc_offset | date: "%H:%M" }}
  </span>
</div>
